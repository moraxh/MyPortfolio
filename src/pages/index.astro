---
  import '@fontsource/space-grotesk'
  import '@fontsource/jetbrains-mono'
  import '@styles/global.css'

	import { Toaster } from '@layouts/components/ui/sonner'
	import Analytics from '@vercel/analytics/astro'
	import SpeedInsights from '@vercel/speed-insights/astro'

	import NeuronalBackground from '@components/NeuronalBackground'
	import Navbar from '@components/Navbar'
	import Hero from '@components/Hero'
	import Contact from '@components/Contact'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Full Stack Developer & AI Engineer portfolio - MoraXh" />
		<title>MoraXh's Portfolio</title>
	</head>
	<body>
    <div class="relative min-h-screen text-slate-200 selection:bg-cyan-500/30 selection:text-cyan-100">
			<NeuronalBackground client:visible />
			<Navbar client:idle />

			<main class="relative z-10">
				<Hero client:visible />
				<div class="space-y-24 pb-24">
					<Contact client:visible />
				</div>
			</main>


		</div>

		<Toaster client:idle position="bottom-right" />
		<Analytics />
		<SpeedInsights />
	</body>
</html>