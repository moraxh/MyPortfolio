---
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/600.css";
import "@fontsource/jetbrains-mono";
import "@styles/global.css";

import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

import RevealObserver from "@components/RevealObserver";
import Navbar from "@components/Navbar";
import Hero from "@components/Hero";
import About from "@components/About";
import Experience from "@components/Experience";
import Skills from "@components/Skills";
import Projects from "@components/Projects";
import Contact from "@components/Contact";
import Footer from "@components/Footer";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/logo.ico" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Jorge Mora, Software engineer building practical AI systems, web platforms, and internal tools."
    />
    <title>Jorge Mora · Portfolio</title>
  </head>
  <body>
    <div class="page-grain" style="position:relative;z-index:0;">
      <Navbar client:load />

      <main style="position:relative;z-index:1;">
        <Hero client:load />
        <About client:visible />
        <Experience client:visible />
        <Skills client:visible />
        <Projects client:visible />
        <Contact client:visible />
      </main>

      <Footer client:visible />
    </div>

    <Analytics />
    <SpeedInsights />

    <script is:inline>
      // Console easter egg — for the devs who open F12
      const s = [
        "%c  Jorge Mora  ",
        "background: oklch(0.62 0.10 250); color: oklch(0.16 0.02 250); font-size: 18px; font-weight: 700; padding: 6px 16px; border-radius: 4px;"
      ]
      const lines = [
        "%cHey, I see you opened DevTools.",
        "%cYou're probably a developer. So am I.",
        "%cIf you want to see how this is built: github.com/moraxh",
        "%cIf you want to work together: contact@moraxh.dev",
        "%c↑ ↑ ↓ ↓ ← → ← → B A  (you know what to do)",
      ]
      console.log(...s)
      lines.forEach(l => console.log(l, "color: oklch(0.78 0.006 85); font-size: 13px;"))

      // Konami code easter egg — guard against HMR duplicate listeners
      if (!window.__konamiReady) {
        window.__konamiReady = true
        const KONAMI = ["ArrowUp","ArrowUp","ArrowDown","ArrowDown","ArrowLeft","ArrowRight","ArrowLeft","ArrowRight","b","a"]
        let kIdx = 0
        document.addEventListener("keydown", (e) => {
          if (e.key === KONAMI[kIdx]) {
            kIdx++
            if (kIdx === KONAMI.length) {
              kIdx = 0
              const existing = document.getElementById("konami-overlay")
              if (existing) existing.remove()
              const overlay = document.createElement("div")
              overlay.id = "konami-overlay"
              overlay.innerHTML = `
                <div class="konami-box">
                  <div class="konami-badge">// easter egg unlocked</div>
                  <div class="konami-ascii">
┌───────────────────────────────────────┐
│          Terry A. Davis               │
│          1969 – 2018                  │
├───────────────────────────────────────┤
│                                       │
│  "An idiot admires complexity,        │
│   a genius admires simplicity."       │
│                                       │
│  Built an OS alone. 100,000 lines.    │
│  Real GCC. Real kernel. Real God.     │
│  The smartest programmer ever.        │
│                                       │
│          TempleOS forever.            │
└───────────────────────────────────────┘</div>
                  <p class="konami-note">You found it. Not bad.</p>
                  <button class="konami-close" onclick="document.getElementById('konami-overlay').remove()">close ×</button>
                </div>
              `
              document.body.appendChild(overlay)
              setTimeout(() => overlay.classList.add("konami-in"), 10)
            }
          } else {
            kIdx = e.key === KONAMI[0] ? 1 : 0
          }
        })
      }
    </script>

  </body>
</html>

<RevealObserver client:load />
